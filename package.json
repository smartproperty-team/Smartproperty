{
  "name": "smartproperty-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SmartProperty - Smart Property Management Platform",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ..",
    "seed": "cd backend && npm run seed",
    "seed:users": "cd backend && npm run seed:users"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "concurrently": "^8.2.2"
  }
}
