# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 4. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=536589803506-2m576m65ekecq64o4ggvfov1iig9ilpc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=http://localhost:5173/auth/google/callback

