FACEBOOK_CALLBACK_URL=https://nikki-uncapturable-smarmily.ngrok-free.dev/api/auth/facebook/callback
FACEBOOK_FRONTEND_CALLBACK_URL=https://nikki-uncapturable-smarmily.ngrok-free.dev/auth/facebook/callback

# Logging
LOG_LEVEL=debug

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true