# ===========================================
# SMARTPROPERTY BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Development Environment

# Application
NODE_ENV=development
PORT=3000
APP_NAME=SmartProperty API

# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=smartproperty
MONGODB_USERNAME=smartproperty_user
MONGODB_PASSWORD=smartproperty_pass_2024
MONGODB_URI=mongodb://smartproperty_user:smartproperty_pass_2024@localhost:27017/smartproperty?authSource=admin

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password_2024
REDIS_URL=redis://:redis_dev_password_2024@localhost:6379

# JWT Configuration
JWT_SECRET=smartproperty_jwt_secret_dev_2024_change_in_prod
JWT_EXPIRATION=1d
JWT_REFRESH_SECRET=smartproperty_refresh_secret_dev_2024
JWT_REFRESH_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartproperty-uploads

# Email Configuration (SMTP - using MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=mailhog
SMTP_PASSWORD=mailhog
SMTP_FROM_NAME=SmartProperty
SMTP_FROM_EMAIL=noreply@smartproperty.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FACEBOOK_APP_ID=1204648061866117
FACEBOOK_APP_SECRET=7f87c325d62698d86a95810c38b6307c
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./apple-key.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback