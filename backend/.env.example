# ===========================================
# SMARTPROPERTY BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and update values

# ===========================
# Application
# ===========================
NODE_ENV=development
APP_PORT=3000
APP_NAME=SmartProperty API
APP_CORS_ORIGIN=http://localhost:5173
APP_FRONTEND_URL=http://localhost:3000

# ===========================
# MongoDB Configuration
# ===========================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=smartproperty
MONGODB_USERNAME=smartproperty_user
MONGODB_PASSWORD=smartproperty_pass_2024

# Alternative: Use full MongoDB URI
# MONGODB_URI=mongodb://smartproperty_user:smartproperty_pass_2024@localhost:27017/smartproperty?authSource=admin

# ===========================
# Redis Configuration
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================
# JWT Configuration
# ===========================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars_change_in_production
JWT_EXPIRATION=1d
JWT_REFRESH_EXPIRATION=7d

# ===========================
# Email Configuration (SMTP)
# ===========================
# Using Mailtrap for development (recommended)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_SECURE=true
MAIL_AUTH_USER=your_mailtrap_username
MAIL_AUTH_PASS=your_mailtrap_password
MAIL_FROM_NAME=SmartProperty
MAIL_FROM_ADDRESS=noreply@smartproperty.com

# For Gmail (enable less secure apps or use app password):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_AUTH_USER=your_email@gmail.com
# MAIL_AUTH_PASS=your_app_specific_password

# ===========================
# AWS S3 Configuration (for file uploads)
# ===========================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=smartproperty-bucket
AWS_S3_REGION=us-east-1

# ===========================
# Rate Limiting
# ===========================
THROTTLER_TTL=60
THROTTLER_LIMIT=100

# ===========================
# Stripe Payments (Optional)
# ===========================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ===========================
# Third-party Services (Optional)
# ===========================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
