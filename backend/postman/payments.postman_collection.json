{
  "info": {
    "name": "SmartProperty Payments API",
    "_postman_id": "d2e5b6e7-5f3a-4a38-9c8f-1e73444d0a21",
    "description": "Manual test collection for SmartProperty payment endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "apiPrefix",
      "value": "api"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "paymentId",
      "value": ""
    },
    {
      "key": "leaseId",
      "value": ""
    },
    {
      "key": "tenantId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json?.tokens?.accessToken) {",
              "  pm.collectionVariables.set('jwtToken', json.tokens.accessToken);",
              "}",
              "if (json?.user?.id) {",
              "  pm.collectionVariables.set('tenantId', json.user.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"superadmin@smartproperty.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "auth", "login"]
        },
        "description": "Run this first; it auto-saves tokens.accessToken to jwtToken"
      }
    },
    {
      "name": "Payments - Initiate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Payment initiation succeeded', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json?.id) {",
              "  pm.collectionVariables.set('paymentId', json.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"leaseId\": \"{{leaseId}}\",\n  \"tenantId\": \"{{tenantId}}\",\n  \"amount\": 150000,\n  \"currency\": \"TND\",\n  \"type\": \"rent\",\n  \"method\": \"card\",\n  \"description\": \"April rent payment\",\n  \"idempotencyKey\": \"rent-apr-2026-tenant-1\",\n  \"invoiceId\": \"INV-APR-2026-001\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/initiate",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "initiate"]
        }
      }
    },
    {
      "name": "Payments - Mine",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/mine?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "mine"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "sortBy",
              "value": "createdAt"
            },
            {
              "key": "sortOrder",
              "value": "desc"
            }
          ]
        }
      }
    },
    {
      "name": "Payments - Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/mine/summary",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "mine", "summary"]
        }
      }
    },
    {
      "name": "Payments - Export CSV",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/mine/export?format=csv",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "mine", "export"],
          "query": [
            {
              "key": "format",
              "value": "csv"
            }
          ]
        }
      }
    },
    {
      "name": "Payments - Get By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/{{paymentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "{{paymentId}}"]
        }
      }
    },
    {
      "name": "Payments - Refund",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 50000,\n  \"reason\": \"requested_by_customer\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/{{apiPrefix}}/payments/{{paymentId}}/refund",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "payments", "{{paymentId}}", "refund"]
        }
      }
    }
  ]
}
