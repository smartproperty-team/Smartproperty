# ===========================================
# SmartProperty AI Services - Environment
# ===========================================

# Application
APP_NAME=SmartProperty AI Services
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb://smartproperty:smartproperty123@localhost:27017/smartproperty?authSource=admin
MONGODB_DB_NAME=smartproperty

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=smartproperty_redis_secret
REDIS_DB=1

# Backend API (NestJS)
BACKEND_API_URL=http://localhost:3000/api

# JWT (same as backend for token validation)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# AWS S3 (for model storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartproperty-ai-models

# ML Model Paths
MODEL_PATH=./models
RECOMMENDATION_MODEL_PATH=./models/recommendation
PRICE_MODEL_PATH=./models/pricing
IMAGE_MODEL_PATH=./models/image_analysis

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
