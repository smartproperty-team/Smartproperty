# ===========================================
# SMARTPROPERTY FRONTEND - ENVIRONMENT VARIABLES
# ===========================================
# Development Environment

# API Configuration - Use relative path to leverage Vite proxy in development
# Leave empty or set to /api for local development
# For production, set to the full API URL like https://api.smartproperty.com/api
VITE_API_URL=/api
VITE_API_GRAPHQL_URL=/graphql

# App Configuration
VITE_APP_NAME=SmartProperty
VITE_APP_VERSION=1.0.0

# Mapbox Configuration
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Feature Flags
VITE_ENABLE_3D_TOURS=true
VITE_ENABLE_AI_FEATURES=false

# Environment
VITE_NODE_ENV=development